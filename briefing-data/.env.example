# FRED API key (free: https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_api_key_here

# Twelve Data API key (free: https://twelvedata.com/pricing -- 800 calls/day)
# Used for market data (S&P 500, XBI, Russell 2000). Falls back to yfinance if not set.
TWELVE_DATA_API_KEY=your_twelvedata_api_key_here

# NCBI API key (optional, free: https://www.ncbi.nlm.nih.gov/account/)
# Increases PubMed E-utilities rate limit from 3/sec to 10/sec. Works without it.
NCBI_API_KEY=

# Path to m365 CLI directory (optional, default: ~/GitHub/m365-cli/)
# Only needed if using "m365" email method
M365_CLI_PATH=
